# 📁 .env.example - Environment variables template
# 🎯 Core function: Template for production environment variables
# 🔗 Key dependencies: PostgreSQL, JWT, Redis
# 💡 Usage: Copy to .env and fill with actual values

# Database Configuration
POSTGRES_PASSWORD=your-secure-postgres-password
DATABASE_URL=postgresql://webmaster:your-secure-postgres-password@postgres:5432/webmaster

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Redis Configuration (optional)
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379

# Application Configuration
NODE_ENV=production
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
VITE_API_URL=http://localhost:5000/api

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000

# File Upload (if needed)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/app/uploads
