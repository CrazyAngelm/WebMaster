# 📁 Dockerfile.dev - Development frontend container
# 🎯 Core function: Development environment with hot reload
# 🔗 Key dependencies: Node.js, Vite
# 💡 Usage: Development with live code reloading

FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy source code
COPY . .

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

# Change ownership
RUN chown -R nodejs:nodejs /app
USER nodejs

# Expose port
EXPOSE 5173

# Start development server
CMD ["npm", "run", "dev"]
