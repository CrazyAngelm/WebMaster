# 📁 .dockerignore - Frontend Docker ignore file
# 🎯 Core function: Exclude unnecessary files from Docker build context
# 🔗 Key dependencies: Docker build optimization
# 💡 Usage: Reduce build context size and improve build speed

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist
build

# Development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Docker files
Dockerfile*
docker-compose*
.dockerignore

# Documentation
README.md
docs

# Cache
.cache
.parcel-cache

# Logs
logs
*.log

# Testing
coverage
.nyc_output

# Temporary files
*.tmp
*.temp

# Vite
.vite

# TypeScript
*.tsbuildinfo

# ESLint
.eslintcache

# Storybook
storybook-static

# Lock files (already copied separately)
package-lock.json
yarn.lock
pnpm-lock.yaml
