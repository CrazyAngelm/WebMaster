.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Docker files
Dockerfile*
docker-compose*
.dockerignore

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
logs
*.log

# Testing
coverage
.nyc_output

