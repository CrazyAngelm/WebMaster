// 📁 server/prisma/schema.prisma - Database schema
// 🎯 Core function: Defines models for User, Character, and Inventory
// 🔗 Key dependencies: Prisma
// 💡 Usage: Used by Prisma to generate client and migrate database

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  login        String      @unique
  passwordHash String
  role         String      @default("USER")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  characters   Character[]
}

model Character {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  name          String    @unique
  raceId        String
  rankId        String
  description   String    @default("")
  bio           String    @default("")
  
  // Stats and complex objects stored as String (JSON) for flexibility
  stats         String    // CharacterStats (JSON string)
  bonuses       String    // CharacterBonuses (JSON string)
  professions   String    // CharacterProfession[] (JSON string)
  location      String    // { locationId, buildingId, position } (JSON string)
  
  isDead        Boolean   @default(false)
  money         Int       @default(0)
  activeQuests  String    @default("[]") // Quest[] (JSON string)
  lastTrainTime Float?    // * Track last training time (in server time hours, float for sub-hour precision)
  lastRestTime  Float?    // * Track last rest time (in server time hours, float for sub-hour precision)
  skills        String    @default("[]") // UUID[] (JSON string) - CharacterSkill IDs for quick access
  npcDialogHistory String @default("{}") // NPC dialog history (JSON string)
  npcReputation    String @default("{}") // NPC reputation data (JSON string)
  completedQuests  String @default("[]") // CompletedQuest[] (JSON string)
  lastLocationChange String? // LocationHistory (JSON string) - tracks last location change
   
  inventory     Inventory?
  characterSkills CharacterSkill[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Inventory {
  id          String    @id @default(uuid())
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  baseSlots   Int       @default(10)
  items       String    // ExistingItem[] (JSON string)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Race {
  id             String @id
  name           String
  description    String
  baseSpeedId    String
  innateSkills   String // UUID[] (JSON string)
  passiveEffects String // UUID[] (JSON string)
}

model Rank {
  id                     String @id
  order                  Int
  name                   String
  maxEssence             Int
  minEssenceRoll         Int?
  maxArtifacts           Int
  maxSkills              Int
  breakthroughConditions String // string[] (JSON string)
}

model ItemTemplate {
  id                String  @id
  name              String
  type              String
  category          String?
  rarity            String
  stackSize         Int
  isUnique          Boolean
  baseEssence       Int?
  maxEssence        Int?
  penetration       String?
  distance          String?
  baseDurability    Int?
  ignoreDamage      Int?
  hitPenalty        Int?
  evasionPenalty    Int?
  speedPenalty      Int?
  accuracyBonus     Int?    @default(0)
  evasionBonus      Int?    @default(0)
  initiativeBonus   Int?    @default(0)
  resistanceBonus   Int?    @default(0)
  slotCount         Int?
  effects           String? // UUID[] (JSON string)
  description       String?
  basePrice         Int?
  shieldType        String? // 'LIGHT' | 'MEDIUM' | 'HEAVY' | 'SUPER_HEAVY'
  shieldEvasionPenalty Int? // Penalty to evasion (-30, -70, -150, 0)
}

model Recipe {
  id               String  @id
  resultTemplateId String
  profession       String
  rankRequired     Int
  ingredients      String  // { templateId, quantity }[] (JSON string)
  stationRequired  String?
}

model MonsterTemplate {
  id           String  @id
  name         String
  rankOrder    Int
  baseEssence  Int
  speedId      String  @default("speed-ordinary")
  description  String?
  skills       String  // UUID[] (JSON string)
  lootTable    String  // { templateId, chance, minQuantity, maxQuantity }[] (JSON string)
  npcMonsters  NPCMonster[]
}

model NPCTemplate {
  id           String  @id
  name         String
  npcType      String  // merchant, guard, questgiver, villager, mysterious
  rankOrder    Int
  baseEssence  Int
  speedId      String  @default("speed-ordinary")
  description  String?
  personality  String
  greeting     String?
  skills       String  // UUID[] (JSON string)
  lootTable    String  // { templateId, chance, minQuantity, maxQuantity }[] (JSON string)
}

model Quest {
  id           String @id
  title        String
  description  String
  objectives   String // QuestObjective[] (JSON string)
  rewards      String // { money?, essence?, items? } (JSON string)
  status       String
  rankRequired Int
}

model Location {
  id          String @id
  name        String
  description String
  zoneType    String
  buildings   String // UUID[] (JSON string)
}

model Building {
  id            String  @id
  locationId    String
  name          String
  description   String
  hasShop       Boolean
  canRest       Boolean @default(false)
  shopInventory String? // UUID
  workstations  String  // string[] (JSON string)
}

model NPCMonster {
  id            String   @id @default(uuid())
  npcId         String   @unique
  monsterId     String
  monster       MonsterTemplate @relation(fields: [monsterId], references: [id])
  essenceBonus  Int      @default(0)
  protectionBonus Int    @default(0)
  accuracyBonus  Int      @default(0)
  evasionBonus  Int      @default(0)
  initiativeBonus Int     @default(0)
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NPC {
  id            String   @id @default(uuid())
  name          String
  description   String
  personality   String
  greeting      String?
  buildingId    String?
  locationId    String?
  npcType       String   // merchant, guard, questgiver, villager, mysterious
  templateId    String?  // Reference to NPCTemplate
  monsterId     String?  // @unique - Reference to NPCMonster for combat stats
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([monsterId])
}

model LocationConnection {
  id             String @id
  fromLocationId String
  toLocationId   String
}

model ProfessionRankThreshold {
  id     String @id @default(uuid())
  rank   Int
  minExp Int
  maxExp Float  // Using Float because maxExp can be Infinity
  name   String
}

model Speed {
  id                String @id
  name              String
  category          String
  distancePerAction Int
}

model GameEvent {
  id                  String  @id
  title               String
  description         String
  rarity              String
  image               String?
  choices             String? // GameEventChoice[] (JSON string)
  autoTriggerNextId   String?
  triggerCondition    String?
}

model GameConfig {
  key   String @id
  value String // JSON string for flexibility
}

model EffectTemplate {
  id              String  @id
  name            String
  type            String  // EffectType enum as string
  duration        Int     // turns
  value           Int
  parameter       String? // which stat it affects
  isNegative      Boolean @default(false)
  description     String?
}

model SkillTemplate {
  id              String  @id
  name            String
  description     String
  rarity          String  // Rarity enum
  castTime        Int     // Turns to prepare (1-2+)
  cooldown        Int     // Turns before reuse
  targetType      String  // 'SELF' | 'TARGET' | 'AREA'
  distance        String? // JSON: { minRange, maxRange } or legacy string
  penetration     String? // PenetrationType enum
  alwaysPenetrates Boolean @default(false)
  effects         String? // UUID[] (JSON string)
  isCombat        Boolean @default(true)
  isStarter       Boolean @default(false)
  
  characterSkills CharacterSkill[]
}

model CharacterSkill {
  id                String   @id @default(uuid())
  characterId       String
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillTemplateId   String
  skillTemplate     SkillTemplate @relation(fields: [skillTemplateId], references: [id])
  currentCooldown  Int      @default(0)
  castTimeRemaining Int?     // null if not casting
  isItemSkill       Boolean  @default(false)
  baseEssence       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Battle {
  id               String              @id @default(uuid())
  locationId       String
  status           String              @default("ACTIVE")
  currentTurnIndex Int                 @default(0)
  log              String              @default("[]")
  participants     BattleParticipant[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model BattleParticipant {
  id                String    @id @default(uuid())
  battleId          String
  battle            Battle    @relation(fields: [battleId], references: [id], onDelete: Cascade)
  characterId       String?
  monsterTemplateId String?
  name              String
  initiative        Int
  currentHp         Int
  currentProtection Int
  maxHp             Int
  maxProtection     Int
  mainActions       Int       @default(1)
  bonusActions      Int       @default(1)
  isPlayer          Boolean   @default(false)
  distance          Float     @default(0.0)
  bonuses           String?   // CharacterBonuses (JSON string)
  activeEffects     String    @default("[]") // ActiveEffect[] (JSON string)
  isBlocking        Boolean   @default(false) // Active shield block flag
  status            String    @default("ALIVE") // ALIVE | DOWNED | DEAD
  downedRoundsRemaining Int   @default(0)
}
