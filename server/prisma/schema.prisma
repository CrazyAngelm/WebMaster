// 📁 server/prisma/schema.prisma - Database schema
// 🎯 Core function: Defines models for User, Character, and Inventory
// 🔗 Key dependencies: Prisma
// 💡 Usage: Used by Prisma to generate client and migrate database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  login        String      @unique
  passwordHash String
  role         String      @default("USER")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  characters   Character[]
}

model Character {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  name          String    @unique
  raceId        String
  rankId        String
  description   String    @default("")
  bio           String    @default("")
  
  // Stats and complex objects stored as String (JSON) for flexibility
  stats         String    // CharacterStats (JSON string)
  bonuses       String    // CharacterBonuses (JSON string)
  professions   String    // CharacterProfession[] (JSON string)
  location      String    // { locationId, buildingId, position } (JSON string)
  
  isDead        Boolean   @default(false)
  money         Int       @default(0)
  activeQuests  String    @default("[]") // Quest[] (JSON string)
  lastTrainTime Int?
  lastRestTime  Int?      // * Track last rest time (in server time hours)
  
  inventory     Inventory?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Inventory {
  id          String    @id @default(uuid())
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  baseSlots   Int       @default(10)
  items       String    // ExistingItem[] (JSON string)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Race {
  id             String @id
  name           String
  description    String
  baseSpeedId    String
  innateSkills   String // UUID[] (JSON string)
  passiveEffects String // UUID[] (JSON string)
}

model Rank {
  id                     String @id
  order                  Int
  name                   String
  maxEssence             Int
  minEssenceRoll         Int?
  maxArtifacts           Int
  maxSkills              Int
  breakthroughConditions String // string[] (JSON string)
}

model ItemTemplate {
  id                String  @id
  name              String
  type              String
  category          String?
  rarity            String
  stackSize         Int
  isUnique          Boolean
  baseEssence       Int?
  maxEssence        Int?
  penetration       String?
  distance          String?
  baseDurability    Int?
  ignoreDamage      Int?
  hitPenalty        Int?
  evasionPenalty    Int?
  speedPenalty      Int?
  slotCount         Int?
  effects           String? // UUID[] (JSON string)
  description       String?
  basePrice         Int?
}

model Recipe {
  id               String  @id
  resultTemplateId String
  profession       String
  rankRequired     Int
  ingredients      String  // { templateId, quantity }[] (JSON string)
  stationRequired  String?
}

model MonsterTemplate {
  id           String  @id
  name         String
  rankOrder    Int
  baseEssence  Int
  description  String?
  skills       String  // UUID[] (JSON string)
  lootTable    String  // { templateId, chance, minQuantity, maxQuantity }[] (JSON string)
}

model Quest {
  id           String @id
  title        String
  description  String
  objectives   String // QuestObjective[] (JSON string)
  rewards      String // { money?, essence?, items? } (JSON string)
  status       String
  rankRequired Int
}

model Location {
  id          String @id
  name        String
  description String
  zoneType    String
  buildings   String // UUID[] (JSON string)
}

model Building {
  id            String  @id
  locationId    String
  name          String
  description   String
  hasShop       Boolean
  canRest       Boolean @default(false)
  shopInventory String? // UUID
  workstations  String  // string[] (JSON string)
}

model LocationConnection {
  id             String @id
  fromLocationId String
  toLocationId   String
}

model ProfessionRankThreshold {
  id     String @id @default(uuid())
  rank   Int
  minExp Int
  maxExp Float  // Using Float because maxExp can be Infinity
  name   String
}

model Speed {
  id                String @id
  name              String
  category          String
  distancePerAction Int
}

model GameEvent {
  id                  String  @id
  title               String
  description         String
  rarity              String
  image               String?
  choices             String? // GameEventChoice[] (JSON string)
  autoTriggerNextId   String?
  triggerCondition    String?
}

model GameConfig {
  key   String @id
  value String // JSON string for flexibility
}
